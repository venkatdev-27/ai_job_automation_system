.env
.env.production
.env.production.local
.env.local
.env.*.local

# API keys
*.key
*.pem
*.crt

# Data directories
chrome_profile/
temp_resumes/
chroma_db/
sessions/
logs/

# Temporary files
*.tmp
*.swp
*~
.DS_Store

# Local job-automation scratch scripts and trigger payloads
job_automation_system/node-api/check_apps.js
job_automation_system/scratch/check_apps.py
job_automation_system/scratch/check_linkedin.py
job_automation_system/scratch/clean_student.py
