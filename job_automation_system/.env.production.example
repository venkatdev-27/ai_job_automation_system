# Job Automation System - Production Environment Template
# ==============================================================================
# COPY THIS FILE TO .env.production ON YOUR VPS
# THEN FILL IN YOUR REAL VALUES
#
# DO NOT COMMIT THIS FILE TO GIT!
# ==============================================================================

# =============================================================================
# MONGODB (Get your connection string from MongoDB Atlas)
# ==============================================================================
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.x.mongodb.net/ai_bot_resumes?appName=Cluster0
MONGO_DB=ai_bot_resumes

# =============================================================================
# REDIS (Leave as 'redis' - this is the Docker service name)
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# CELERY (Redis as broker)
# ==============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# =============================================================================
# AI ENGINE TOGGLE
# ==============================================================================
AI_ENGINE_ENABLED=true
RESUME_BATCH_SIZE=3

# =============================================================================
# RATE LIMITING (tasks per minute)
# ==============================================================================
NAUKRI_RATE_LIMIT=10
LINKEDIN_RATE_LIMIT=6
FOUNDIT_RATE_LIMIT=10

# =============================================================================
# CONCURRENCY LIMITS
# ==============================================================================
MAX_PARALLEL_BROWSERS=10
BROWSER_CONCURRENCY_NAUKRI=6
BROWSER_CONCURRENCY_LINKEDIN=4
BROWSER_CONCURRENCY_FOUNDIT=4

# =============================================================================
# ANTI-BOT SETTINGS
# ==============================================================================
MIN_DELAY_SECONDS=1.5
MAX_DELAY_SECONDS=3.0
LINKEDIN_MIN_DELAY=5
LINKEDIN_MAX_DELAY=15
EXTRA_DELAY_AFTER_APPLIES=5
EXTRA_DELAY_MIN=4.0
EXTRA_DELAY_MAX=6.0

# =============================================================================
# CDP (Chrome DevTools Protocol)
# ==============================================================================
CDP_URL=http://chrome-cdp:3000
USE_CDP=true
CDP_HOST=chrome-cdp
CDP_PORT=3000

# =============================================================================
# RETRY CONFIGURATION
# ==============================================================================
MAX_RETRIES=3
RETRY_BACKOFF_BASE=1
RETRY_BACKOFF_MAX=600
IDEMPOTENCY_TTL=86400
LOCK_TTL=1800

# =============================================================================
# CIRCUIT BREAKER
# ==============================================================================
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300

# =============================================================================
# API CONFIGURATION (AI Providers)
# ==============================================================================
# GET YOUR KEYS FROM:
# - Groq: https://console.groq.com/keys
# - Google AI Studio: https://makersuite.google.com/app/apikey
# - OpenRouter: https://openrouter.ai/keys
# ==============================================================================
GROQ_API_URL=https://api.groq.com/openai/v1
OPENROUTER_API_URL=https://openrouter.ai/api/v1
MINIMAX_API_URL=https://api.minimax.chat/v1

# REQUIRED: Get your Groq API key from https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# OPTIONAL: Gemini API key (for backup LLM)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OPTIONAL: OpenRouter API key (for diverse LLM access)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# OPTIONAL: MiniMax API key
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE

# =============================================================================
# LOCAL API (AI Engine service URL)
# ==============================================================================
LOCAL_API_URL=http://ai-engine:8000

# =============================================================================
# CLOUDINARY (For resume storage)
# ==============================================================================
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# =============================================================================
# PLAYWRIGHT
# ==============================================================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# =============================================================================
# CREDENTIALS ENCRYPTION (Generate with: openssl rand -hex 32)
# ==============================================================================
ENCRYPTION_KEY=CHANGE_THIS_WITH_SECURE_KEY_GENERATED_BY_OPENSSL

# =============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# ATS MATCH THRESHOLD
# ==============================================================================
ATS_THRESHOLD=30.0

# =============================================================================
# WAVE MODE - ANTI-DETECTION STRATEGY
# ==============================================================================
WAVE_MODE=true
JOBS_PER_WAVE=5
STUDENTS_PER_WAVE=5
WAVE_PAUSE_MIN=30
WAVE_PAUSE_MAX=90
STUDENT_SPACING_MIN=30
STUDENT_SPACING_MAX=60
WAVE_JITTER_MAX=30
TIME_BASED_WEIGHTS=true
HUMAN_ACTIVITY_ENABLED=true
DAY_DISTRIBUTION_ENABLED=true

# =============================================================================
# DAY DISTRIBUTION TARGETS
# ==============================================================================
DIST_MORNING_PCT=30
DIST_AFTERNOON_PCT=25
DIST_EVENING_PCT=35
DIST_NIGHT_PCT=10

# =============================================================================
# CELERY BEAT SCHEDULE (Auto-Run times in 24h format)
# ==============================================================================
BEAT_SCHEDULE_TIMES=06:00,11:00,17:00,20:00
BEAT_PLATFORMS=naukri,linkedin,foundit
CELERY_BEAT_ENABLED=true
BEAT_RETRY_DELAY=300
BEAT_MAX_RETRIES=3

# =============================================================================
# AUTO-PRODUTION SETTINGS
# ==============================================================================
# Set to 'true' for production
RUN_ENV=production
DEBUG=false
IN_DOCKER=true

# =============================================================================
# GRAFANA ADMIN PASSWORD
# ==============================================================================
# Access Grafana at http://your-vps:3001
# Default username: admin
# Default password: (set below)
# ==============================================================================
GRAFANA_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# =============================================================================
# AUTO-START/S TOP SETTINGS
# ==============================================================================
# Enable auto-start on server boot
AUTO_START_ENABLED=true

# Auto-stop time (24h format, default 23:59)
AUTO_STOP_TIME=23:59

# Daily job limit (0 = unlimited)
DAILY_JOB_LIMIT=100
