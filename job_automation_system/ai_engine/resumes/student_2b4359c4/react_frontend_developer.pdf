    padding-bottom: 2px;
  }
  h3 {
    margin: 10px 0 2px 0;
    font-size: 11pt;
    font-weight: 700;
  }
  p {
    margin: 0 0 8px 0;
    text-align: justify;
  }
  ul {
    margin: 0 0 10px 18px;
    padding: 0;
    display: block;
    width: 100%;
  }
  li {
    margin: 0 0 4px 0;
    text-align: justify;
  }
</style>
</head>
