# ==============================================================================
# Git Ignore - Job Automation System
# ==============================================================================
# Exclude sensitive files from version control
# ==============================================================================

# ==============================================================================
# ENVIRONMENT FILES (NEVER COMMIT THESE)
# ==============================================================================

# Production secrets
.env
.env.production
.env.production.local
.env.local
.env.*.local

# API keys and credentials
*.key
*.pem
*.crt
credentials.json
secrets.json

# ==============================================================================
# DOCKER VOLUMES (LOCAL DATA)
# ==============================================================================

# Redis data
redis_data/

# Prometheus data
prometheus_data/

# Grafana data
grafana_data/

# Chrome profile
chrome_profile/

# Logs
logs/
*.log

# ==============================================================================
# TEMPORARY FILES
# ==============================================================================

tmp/
temp/
*.tmp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==============================================================================
# PYTHON
# ==============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
ENV/
env/

# Byte-compiled
*.pyc
*.pyo

# ==============================================================================
# NODE (if running dashboard locally)
# ==============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/

# ==============================================================================
# IDE
# ==============================================================================

.vscode/
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# ==============================================================================
# BACKUPS
# ==============================================================================

backups/
*.backup
*.bak
*.backup.tar.gz

# ==============================================================================
# TESTING
# ==============================================================================

.pytest_cache/
.coverage
htmlcov/
coverage/

# ==============================================================================
# CREDENTIALS (EXPLICIT)
# ==============================================================================

# API keys (never commit these)
GROQ_API_KEY=*
GEMINI_API_KEY=*
OPENROUTER_API_KEY=*
CLOUDINARY_API_SECRET=*
ENCRYPTION_KEY=*

# ==============================================================================
# OS-SPECIFIC
# ==============================================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ==============================================================================
# EXCEPTIONS (ALLOW THESE)
# ==============================================================================

# Templates are OK (they have placeholder values)
!.env.example
!.env.production.example

# Prometheus alerts example
!prometheus/alerts.yml

# Dashboards template
!grafana/dashboards/*.json
