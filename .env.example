LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
GROQ_API_KEY=gsk_xxx
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_API_KEY=AIzaSy...

# MongoDB
MONGO_URI=mongodb://localhost:27017/ai_bot_resumes

# Cloudinary Setup
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=tailored_resumes
CLOUDINARY_RESUME_URL=https://res.cloudinary.com/<cloud>/raw/upload/<path>/resume.docx

RUN_ENV=local
HEADLESS=false
JOB_LIMIT=2
LINKEDIN_LOCATION=India
LINKEDIN_EXPERIENCE_FILTER=1,2
LINKEDIN_TIME_FILTER=r604800
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=12000
PIPELINE_DATA_DIR=./temp_pipeline
RESULTS_LOG_PATH=./venkat_pipeline_results.json

# Limits
MAX_TOTAL_APPLIES=32
MAX_APPLIES_PER_PLATFORM=8
